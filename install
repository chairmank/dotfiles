#!/bin/sh

# git submodules must be updated before running this script for the
# first time
# git submodule foreach git pull origin master

BASEDIR=`dirname $(readlink -f $0)`

# Create symlink to .profile
PROFILE="$HOME/.profile"
if [ ! -f $PROFILE ]; then
  echo "Creating file symlink $PROFILE"
  ln -s $BASEDIR/src/profile $PROFILE
else
  echo "$PROFILE file already exists; skipping"
fi

# Copy git-completion.bash to ~/.bash_completion.d/
BASH_COMPLETION="$HOME/.bash_completion.d"
if [ ! -d $BASH_COMPLETION ]; then
  echo "Creating folder $BASH_COMPLETION"
  mkdir $BASH_COMPLETION
fi
GIT_COMPLETION="$BASH_COMPLETION/git-completion.bash"
if [ ! -f $GIT_COMPLETION ]; then
  echo "Creating file symlink $GIT_COMPLETION"
  ln -s $BASEDIR/lib/git/contrib/completion/git-completion.bash $GIT_COMPLETION
else
  echo "$GIT_COMPLETION file already exists; skipping"
fi

# Create symlinks to .bashrc and .bash_aliases
BASHRC="$HOME/.bashrc"
if [ ! -f $BASHRC ]; then
  echo "Creating file symlink $BASHRC"
  ln -s $BASEDIR/src/bashrc $BASHRC
else
  echo "$BASHRC file already exists; skipping"
fi
BASH_ALIASES="$HOME/.bash_aliases"
if [ ! -f $BASH_ALIASES ]; then
  echo "Creating file symlink $BASH_ALIASES"
  ln -s $BASEDIR/src/bash_aliases $BASH_ALIASES
else
  echo "$BASH_ALIASES file already exists; skipping"
fi

# Create symlink to .xsession
XSESSION="$HOME/.xsession"
if [ ! -f $XSESSION ]; then
  echo "Creating file symlink $XSESSION"
  ln -s $BASEDIR/src/xsession $XSESSION
else
  echo "$XSESSION file already exists; skipping"
fi

# Create symlink to .Xresources
XRESOURCES="$HOME/.Xresources"
if [ ! -f $XRESOURCES ]; then
  echo "Creating file symlink $XRESOURCES"
  ln -s $BASEDIR/src/Xresources $XRESOURCES
else
  echo "$XRESOURCES file already exists; skipping"
fi

# Create symlink to lib/solarized/.Xresources
XRESOURCES_SOLARIZED="$HOME/.Xresources_solarized"
if [ ! -f $XRESOURCES_SOLARIZED ]; then
  echo "Creating file symlink $XRESOURCES_SOLARIZED"
  ln -s $BASEDIR/lib/solarized/xresources-colors-solarized/Xresources $XRESOURCES_SOLARIZED
else
  echo "$XRESOURCES_SOLARIZED file already exists; skipping"
fi

# Create symlinks to vim configuration
VIMRC="$HOME/.vimrc"
if [ ! -f $VIMRC ]; then
  echo "Creating file symlink $VIMRC"
  ln -s $BASEDIR/src/vimrc $VIMRC
else
  echo "$VIMRC file already exists; skipping"
fi
VIMDIR="$HOME/.vim"
if [ ! -d $VIMDIR ]; then
  echo "Creating directory symlink $VIMDIR"
    ln -s $BASEDIR/src/vim $VIMDIR
else
  echo "$VIMDIR directory already exists; skipping"
fi

# Create symlink to xmobarrc
# http://projects.haskell.org/xmobar/
XMOBARRC="$HOME/.xmobarrc"
if [ ! -f $XMOBARRC ]; then
  echo "Creating file symlink $XMOBARRC"
  ln -s $BASEDIR/src/xmobarrc $XMOBARRC
else
  echo "$XMOBARRC file already exists; skipping"
fi

# Create symlink to xmonad configuration
XMONADDIR="$HOME/.xmonad"
if [ ! -d $XMONADDIR ]; then
  echo "Creating directory symlink $XMONADDIR"
  ln -s $BASEDIR/src/xmonad $XMONADDIR
else
  echo "$XMONADDIR directory already exists; skipping"
fi
